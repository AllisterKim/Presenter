<Application x:Class="Presenter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MascotWindow.xaml"
             ShutdownMode="OnExplicitShutdown">
    <!--
        ShutdownMode="OnExplicitShutdown":
        오버레이 창을 껐다 켰다 해도 앱 전체가 종료되지 않도록 함.
        실제 종료는 트레이 아이콘 또는 MascotWindow 메뉴에서 Application.Current.Shutdown() 호출로 처리.
    -->
    <Application.Resources>
        <!--
            macOS 스타일 컨텍스트 메뉴. MascotWindow가 코드 비하인드에서 만드는
            ContextMenu/MenuItem/Separator에 TargetType 기반 암시적 스타일로 자동 적용된다.
        -->
        <Style TargetType="ContextMenu">
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#E6262626"
                                CornerRadius="10"
                                BorderBrush="#33FFFFFF"
                                BorderThickness="1"
                                Padding="6">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.35" BlurRadius="24" ShadowDepth="6" Direction="270"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="Bd" CornerRadius="6" Margin="4,1" Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="False"/>
                            </Border>

                            <!-- 하위 항목(Items)이 있을 때 오른쪽으로 펼쳐지는 서브메뉴 팝업 -->
                            <Popup x:Name="Submenu"
                                   Placement="Right"
                                   HorizontalOffset="2"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="#E6262626"
                                        CornerRadius="10"
                                        BorderBrush="#33FFFFFF"
                                        BorderThickness="1"
                                        Padding="6">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.35" BlurRadius="24" ShadowDepth="6" Direction="270"/>
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4D0A84FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="#26FFFFFF"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="10,4"/>
        </Style>
    </Application.Resources>
</Application>
