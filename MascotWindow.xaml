<Window x:Class="Presenter.MascotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="오공 프레젠터"
        Width="150" Height="192"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 마스코트 머리 위에 표시되는 24시간제 현재 시간(메뉴의 "현재 시간 표시" 스위치로 on/off). -->
        <TextBlock x:Name="ClockText"
                   Grid.Row="0"
                   Visibility="Hidden"
                   HorizontalAlignment="Center"
                   Text="00:00:00"
                   FontSize="28.6"
                   FontWeight="Bold"
                   Foreground="White">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" Opacity="0.7" BlurRadius="4" ShadowDepth="0"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- 오랑우탄 모티브의 자체 창작 픽셀아트 마스코트(코드 비하인드에서 셀 단위로 그림). -->
        <Grid x:Name="FaceHost" Grid.Row="1" RenderTransformOrigin="0.5,0.5" SnapsToDevicePixels="True">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="FaceFlip" ScaleX="1" ScaleY="1"/>
                    <ScaleTransform x:Name="FacePulse" ScaleX="1" ScaleY="1"/>
                    <RotateTransform x:Name="FaceWiggle" Angle="0"/>
                    <TranslateTransform x:Name="FaceBounce" Y="0"/>
                </TransformGroup>
            </Grid.RenderTransform>
        </Grid>
    </Grid>
</Window>
