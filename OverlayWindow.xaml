<Window x:Class="Presenter.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PresenterOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        KeyDown="Window_KeyDown"
        MouseRightButtonDown="Window_MouseRightButtonDown">
    <!--
        이 창이 이번 PoC의 핵심 검증 대상입니다:
        1) 전체화면 투명 + Topmost 창이 실제로 다른 창 위에 정상 표시되는가
        2) WebEx/Teams로 화면 공유 시 이 오버레이가 공유 화면에도 함께 캡처되는가
        -> 반드시 실제 화면 공유로 1회 테스트해보세요 (9절 리스크 항목).
    -->
    <Canvas x:Name="DrawCanvas" Background="Transparent">
        <Ellipse x:Name="LaserDot"
                 Width="21.6" Height="21.6"
                 Fill="#4DFF3B30"
                 Stroke="#B3FF3B30"
                 StrokeThickness="1.2"
                 Visibility="Collapsed">
            <Ellipse.Effect>
                <DropShadowEffect Color="#FF3B30" ShadowDepth="0" BlurRadius="28" Opacity="1"/>
            </Ellipse.Effect>
        </Ellipse>
    </Canvas>
</Window>
