<!--
  오공 프레젠터 MSI 설치 프로그램 (WiX Toolset v5).

  빌드 전에 반드시 아래 명령으로 배포용 실행 파일을 먼저 만들어야 합니다(publish 스크립트 참고).
    dotnet publish, self contained, single file, win-x64 -o ..\publish\win-x64

  그 다음 이 스크립트를 wix build로 컴파일하면 Output\PresenterSetup.msi 가 생성됩니다.
    wix build Presenter.wxs -ext WixToolset.UI.wixext -ext WixToolset.Util.wixext -arch x64 -o Output\PresenterSetup.msi

  <SummaryInformation>으로는 주제(Subject)/만든이(Author)까지만 설정할 수 있고,
  탐색기 "속성 > 자세히"의 "제목"(SummaryInformation PID_TITLE)은 WiX가 직접 지원하지
  않아, 빌드 후 아래 PowerShell로 한 번 더 써 줘야 한다(wix build를 다시 하면 초기화되므로
  매번 다시 실행 필요):
    $msiPath = "Output\PresenterSetup.msi"
    $installer = New-Object -ComObject WindowsInstaller.Installer
    $db = $installer.OpenDatabase($msiPath, 1)
    $si = $db.SummaryInformation(6)
    $si.Property(2) = "I'm your bais."
    $si.Persist()
    $db.Commit()

  참고: .msi 파일 자체의 탐색기 아이콘은 Windows가 파일 형식 단위로 고정한 것(msiexec.exe
  아이콘)이라 어떤 설치 프로그램으로도 바꿀 수 없다. ARPPRODUCTICON/Icon으로 바꿀 수 있는
  것은 설치 후 "설정 > 앱" 목록에 뜨는 아이콘뿐이다.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="오공 프레젠터"
           Manufacturer="오공 프레젠터"
           Version="1.0.1"
           UpgradeCode="2F23E377-8DEF-4EF8-8779-EA55EC8D9B3D"
           Scope="perUser"
           Codepage="65001">

    <!-- 관리자 권한 없이 현재 사용자 계정에만 설치 (PRD 요구사항: 관리자 권한 불필요).
         AllowSameVersionUpgrades="yes": Version을 안 올리고 다시 빌드해서 설치해도
         "복구/제거" 유지관리 화면 대신 기존 설치를 지우고 새로 깔끔하게 덮어쓴다. -->
    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="이미 더 최신 버전의 오공 프레젠터가 설치되어 있습니다." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="Presenter" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppProgramMenuFolder" Name="오공 프레젠터" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="MainFeature" Title="오공 프레젠터" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
      <ComponentRef Id="AutoStartRegistry" />
    </Feature>

    <!-- 설치 완료 화면의 "실행" 체크박스 → Presenter.exe 자동 실행 -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="오공 프레젠터 실행" />
    <Property Id="WixShellExecTarget" Value="[INSTALLFOLDER]Presenter.exe" />
    <CustomAction Id="LaunchApplication" DllEntry="WixShellExec" Impersonate="yes" BinaryRef="Wix4UtilCA_X64" />

    <!-- 설치 마법사 배경/배너 그림을 기본 WiX 이미지 대신 마스코트로 교체 -->
    <WixVariable Id="WixUIDialogBmp" Value="Assets\WixUIDialog.bmp" />
    <WixVariable Id="WixUIBannerBmp" Value="Assets\WixUIBanner.bmp" />

    <!-- 첫 화면(WelcomeEulaDlg)에 표시되는 라이선스 텍스트. 지정하지 않으면 WiX 기본
         영문 placeholder가 뜨므로, 한글 이용 안내문으로 교체한다. -->
    <WixVariable Id="WixUILicenseRtf" Value="Assets\License.rtf" />

    <!-- PresenterSetup.msi 파일 자체의 아이콘(탐색기)과 "프로그램 추가/제거" 목록 아이콘을
         오공 얼굴로 지정한다. -->
    <Icon Id="ProductIcon" SourceFile="..\Assets\AppIcon.ico" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon" />

    <!-- 탐색기 "속성 > 자세히" 탭에 표시되는 문서 속성(제목/주제/만든이). -->
    <SummaryInformation Description="OA Tool" Manufacturer="J-Dragon" />

    <ui:WixUI Id="WixUI_Minimal" />

    <!-- WixUI_Minimal의 ExitDialog는 체크박스 컨트롤만 정의할 뿐, "마침" 클릭 시 실제로
         액션을 실행하도록 연결하는 Publish는 없어서 직접 연결해줘야 한다. -->
    <UI>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApplication" Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
    </UI>
  </Package>

  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="6C1B7F0B-8C9E-4C4B-9C3E-4E6F7E2B5A10">
        <File Id="PresenterExe" Source="..\publish\win-x64\Presenter.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <Component Id="StartMenuShortcut" Directory="AppProgramMenuFolder" Guid="9A2D6E4F-1B3C-4A5D-8E7F-2C4B6A8D0E12">
      <Shortcut Id="StartMenuShortcutFile"
                Name="오공 프레젠터"
                Target="[INSTALLFOLDER]Presenter.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveAppProgramMenuFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\Presenter" Name="StartMenuShortcutInstalled" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Fragment>

  <Fragment>
    <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="3E5F8A1C-2D4B-4E6F-9A8C-1B3D5E7F9A21">
      <Shortcut Id="DesktopShortcutFile"
                Name="오공 프레젠터"
                Target="[INSTALLFOLDER]Presenter.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU" Key="Software\Presenter" Name="DesktopShortcutInstalled" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Fragment>

  <Fragment>
    <!-- PC 부팅(로그온) 시 Presenter가 자동 실행되도록 등록. 제거 시 이 값도 함께 삭제된다. -->
    <Component Id="AutoStartRegistry" Directory="INSTALLFOLDER" Guid="7D4A2F6E-3C1B-4D5A-8E9F-0A2C4E6F8B33">
      <RegistryValue Root="HKCU"
                     Key="Software\Microsoft\Windows\CurrentVersion\Run"
                     Name="Presenter"
                     Type="string"
                     Value="&quot;[INSTALLFOLDER]Presenter.exe&quot;"
                     KeyPath="yes" />
    </Component>
  </Fragment>

</Wix>
